---
import { BANNER } from '../config';
interface Props { href?: string; }
const { href } = Astro.props;
const linkUrl = href ?? BANNER.linkUrl;
---

<a class="banner-photo-link" href={linkUrl} target="_blank" rel="noopener sponsored" aria-label={BANNER.name}>
  <img src={BANNER.photoUrl} alt={BANNER.name} />
</a>

<style>
  .banner-photo-link { display:block; margin:32px 0 8px; border-radius:12px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.08); }
  .banner-photo-link img { width:100%; height:auto; display:block; }
</style>
