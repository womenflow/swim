---
import Base from './Base.astro';
import Disclaimer from '../components/Disclaimer.astro';
import Banner from '../components/Banner.astro';
import ProductCTA from '../components/ProductCTA.astro';
import { SITE } from '../config';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  image?: string;
  shopUrl?: string;
  shopLabel?: string;
  shopPitch?: string;
}
const { title, description, pubDate, tags, image, shopUrl, shopLabel, shopPitch } =
  Astro.props;
const dateStr = pubDate.toISOString().slice(0, 10);
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// SEO: Article structured data (JSON-LD)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: { '@type': 'Organization', name: SITE.name },
  publisher: { '@type': 'Organization', name: SITE.name },
  mainEntityOfPage: canonical,
  ...(image ? { image: new URL(image, Astro.site).href } : {}),
};
---

<Base title={`${title} | ${SITE.name}`} description={description} image={image}>
  <article>
    <h1 class="post-title">{title}</h1>
    <p class="meta">{dateStr}</p>
    <div class="content"><slot /></div>
    {shopUrl && shopPitch && (
      <ProductCTA url={shopUrl} label={shopLabel ?? 'Shop Bubblelime'} pitch={shopPitch} />
    )}
    <Disclaimer />
    <Banner href={shopUrl} />
    <div class="tags">{tags.map((t) => <span>{t}</span>)}</div>
    <p style="margin-top:32px"><a class="back" href="/">← All articles</a></p>
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Base>
